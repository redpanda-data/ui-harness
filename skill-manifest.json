{
  "$comment": "Source of truth for hook configurations and hook inventory exemptions. Generates .claude/settings.json, hooks/hooks.json, .codex/hooks.json, and hooks/codex-hooks.json. Run scripts/generate-hook-configs.sh to regenerate and verify no hook script is silently unconfigured.",
  "version": "4.10.2",
  "hooks": {
    "SessionStart": {
      "": [
        "session-env.sh",
        "rtk-install-check.sh",
        "llm-env.sh"
      ]
    },
    "UserPromptSubmit": {
      "": [
        "user-prompt-context.sh",
        "intent-detect.sh"
      ]
    },
    "PostCompact": {
      "": [
        "post-compact-context.sh"
      ]
    },
    "PreCompact": {
      "": [
        "pre-compact.sh"
      ]
    },
    "PostToolUseFailure": {
      "Bash": [
        "post-tool-failure.sh"
      ]
    },
    "FileChanged": {
      "package.json|bun.lockb|package-lock.json": [
        "file-changed-deps.sh"
      ],
      "*.proto|*.graphql|*.graphqls": [
        "file-changed-schema.sh"
      ],
      "biome.jsonc|biome.json|tsconfig.json|tsconfig.*.json|vitest.config.*": [
        "file-changed-config.sh"
      ],
      "src/env.ts": [
        "file-changed-env.sh"
      ],
      "skill-manifest.json": [
        "file-changed-manifest.sh"
      ]
    },
    "WorktreeCreate": {
      "": [
        "worktree-create.sh"
      ]
    },
    "SessionEnd": {
      "": [
        "session-end.sh"
      ]
    },
    "PreToolUse": {
      "Edit|Write|Bash": [
        "violation-nudge.sh"
      ],
      "Bash": [
        "enforce-toolchain.sh",
        "llm-test-flags.sh",
        "conventional-commits-check.sh",
        "branch-safety-check.sh",
        "bash-verbose-guard.sh",
        "rtk-rewrite.sh"
      ],
      "mcp__.*": [
        "mcp-ban.sh"
      ],
      "Read": [
        "read-size-guard.sh"
      ],
      "WebFetch": [
        "webfetch-dedup.sh"
      ],
      "Agent|Task": [
        "subagent-length-cap.sh"
      ]
    },
    "PostToolUse": {
      "Edit|Write": [
        "vendor-file-check.sh",
        "ui-registry-warn.sh",
        "react-rules-check.sh",
        "tailwind-check.sh",
        "accessibility-check.sh",
        "zustand-check.sh",
        "tanstack-router-check.sh",
        "tanstack-router-gen.sh",
        "connect-query-check.sh",
        "react-compiler-check.sh",
        "env-validation-check.sh",
        "bundle-guard.sh",
        "test-perf-check.sh",
        "ux-copy-check.sh",
        "orchestration-guidance.sh",
        "form-mode-check.sh",
        "file-size-check.sh",
        "hook-location-check.sh",
        "mutation-side-effect-check.sh",
        "connect-error-check.sh",
        "connect-error-format-check.sh",
        "unhappy-path-check.sh",
        "tdd-prompt-check.sh",
        "error-boundary-check.sh",
        "field-mask-check.sh",
        "route-visual-test-check.sh",
        "legacy-linter-check.sh",
        "biome-ignore-check.sh",
        "legacy-import-check.sh",
        "test-convention-check.sh",
        "form-watch-check.sh",
        "as-cast-check.sh",
        "ts-no-escape-hatches-check.sh",
        "tsconfig-strict-check.sh",
        "llm-failure-mode-check.sh",
        "security-audit-check.sh",
        "mutation-naming-check.sh",
        "magic-number-check.sh",
        "disabled-button-tooltip-check.sh",
        "query-pattern-check.sh",
        "copyright-check.sh",
        "zustand-subscription-check.sh",
        "url-state-check.sh",
        "duplicate-function-check.sh",
        "mutation-onerror-check.sh",
        "edit-loop-check.sh",
        "lockfile-sync-check.sh",
        "connect-error-fieldmap-check.sh",
        "proto-form-parallel-state-check.sh",
        "form-setvalue-options-check.sh",
        "form-error-summary-check.sh"
      ],
      "Bash": [
        "llm-truncate.sh",
        "consecutive-failure-check.sh",
        "test-warning-check.sh"
      ]
    },
    "SubagentStart": {
      "": [
        "subagent-start.sh"
      ]
    },
    "SubagentStop": {
      "self-reviewer|code-reviewer|adversarial-reviewer": [
        "subagent-stop.sh"
      ]
    },
    "Stop": {
      "": [
        "architecture-review-stop.sh",
        "biome-autofix.sh",
        "typecheck-stop.sh",
        "react-doctor-stop.sh",
        "registry-check.sh",
        "orchestration-stop.sh",
        "test-perf-stop.sh",
        "quality-gate-stop.sh",
        "lifecycle-stop.sh",
        "pr-feedback-completeness-stop.sh",
        "ci-warning-audit.sh",
        "perf-regression-stop.sh",
        "violation-summary-stop.sh",
        "cache-telemetry-stop.sh",
        "metrics-summary-stop.sh"
      ]
    }
  },
  "codexOnlyHooks": [
    "codex-permission-request-guard.sh"
  ],
  "supportScripts": [
    "_hook-lib.sh",
    "source-hook-lib.sh"
  ],
  "manualScripts": [
    "cache-telemetry-report.sh"
  ]
}
